{
  "name": "ochre-sdk",
  "version": "1.0.47",
  "type": "module",
  "license": "MIT",
  "description": "Node.js library for working with OCHRE (Online Cultural and Historical Research Environment) data",
  "author": "Firat Ciftci <firatciftci@uchicago.edu> (https://digitalculture.uchicago.edu)",
  "homepage": "https://github.com/uchicago-digitalculture-webdev/ochre-sdk",
  "bugs": {
    "url": "https://github.com/uchicago-digitalculture-webdev/ochre-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uchicago-digitalculture-webdev/ochre-sdk.git"
  },
  "keywords": [
    "ochre",
    "uchicago",
    "digital-culture",
    "digital-humanities",
    "typescript",
    "sdk",
    "parser",
    "cultural-heritage",
    "research"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "imports": {
    "#/*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown src/index.ts --watch",
    "build": "tsdown",
    "lint": "knip; eslint --concurrency auto .",
    "lint:fix": "knip --fix; eslint --concurrency auto --fix .",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "release": "bumpp"
  },
  "changelogithub": {
    "types": {
      "feat": {
        "title": "🚀 Features"
      },
      "fix": {
        "title": "🐞 Bug Fixes"
      },
      "refactor": {
        "title": "🔧 Refactors"
      },
      "test": {
        "title": "🧪 Tests"
      },
      "docs": {
        "title": "📝 Documentation"
      },
      "chore": {
        "title": "🧹 Chores"
      }
    }
  },
  "dependencies": {
    "date-fns": "^4.4.0",
    "fast-equals": "^6.0.0",
    "fast-xml-parser": "^5.8.0",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/node": "^24.13.1",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.1",
    "knip": "^6.16.1",
    "oxfmt": "^0.54.0",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.5.2"
}
